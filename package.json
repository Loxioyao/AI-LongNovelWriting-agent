{
  "name": "ai-novel-writer",
  "version": "2.0.0",
  "description": "多AI协作小说创作平台 - 支持多模型接入、工作流编排、持久化存储",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/index.js\"",
    "dev:front": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --import ./tests/test-env.js --test --test-concurrency=1 tests/providers.test.js tests/crypto.test.js tests/storage.test.js tests/context.test.js",
    "test:providers": "node --import ./tests/test-env.js --test tests/providers.test.js",
    "test:crypto": "node --import ./tests/test-env.js --test tests/crypto.test.js",
    "test:storage": "node --import ./tests/test-env.js --test tests/storage.test.js",
    "test:context": "node --import ./tests/test-env.js --test tests/context.test.js"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.8",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dompurify": "^3.0.11",
    "dotenv": "^16.6.1",
    "element-plus": "^2.6.2",
    "express": "^4.19.2",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "marked": "^12.0.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "sass": "^1.72.0",
    "vite": "^5.2.6"
  }
}
