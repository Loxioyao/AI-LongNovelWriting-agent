# ===== AI服务商配置 =====
# 智谱清言 API Key (https://open.bigmodel.cn)
ZHIPU_API_KEY=

# DeepSeek API Key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# OpenAI API Key (https://platform.openai.com)
OPENAI_API_KEY=

# ===== 加密密钥 =====
# 用于加密存储到数据库中的API Key（32位随机字符串）
# 可用以下命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ===== 服务器配置 =====
PORT=3000
# 数据库文件路径
DB_PATH=./data/novel.db

# ===== 默认AI服务商 =====
# zhipu | deepseek | openai
DEFAULT_PROVIDER=zhipu

# ===== 请求配置 =====
# 流式传输总超时时间（毫秒）- 从请求开始算起，默认10分钟
REQUEST_TIMEOUT=600000
# 流式传输空闲超时时间（毫秒）- 收到最后一个chunk后多久没新数据就超时，默认30秒
STREAM_IDLE_TIMEOUT=30000
# 最大重试次数
MAX_RETRIES=3
